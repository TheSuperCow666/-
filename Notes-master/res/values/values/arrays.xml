<resources>
    
    <!-- Backup format --><!-- 便签导出格式字符串数组：包含文件夹名、日期、内容等导出模板 -->
    <string-array name="format_for_exported_note">
        <item>-%s</item>      <!-- format_folder_name --><!-- 文件夹名称格式化模板：前缀- + 文件夹名 -->
        <item>--%s</item>     <!-- format_folder_note_date --><!-- 文件夹下便签日期格式化模板：前缀-+ 日期 -->
        <item>--%s</item>     <!-- format_note_date --><!-- 便签日期格式化模板：前缀- + 日期 -->
        <item>--%s</item>     <!-- format_note_content --> <!-- 便签内容格式化模板：前缀- + 内容 -->
    </string-array>

    <!-- 便签分享方式字符串数组：定义支持的分享渠道 -->
    <string-array name="menu_share_ways">
        <item>Messaging</item><!-- 短信分享 -->
        <item>Email</item><!-- 邮件分享 -->
    </string-array>
</resources>