<!--深色主题文本颜色状态选择器-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <!--控件按下状态文本颜色-->
  <item android:state_pressed="true" android:color="#88555555" />
 <!--控件选中状态文本颜色-->
  <item android:state_selected="true" android:color="#ff999999" />
 <!--默认状态文本颜色-->
  <item android:color="#ff000000" />
</selector>